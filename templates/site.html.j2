<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ data.meta.title }}</title>
    <meta
      name="description"
      content="A hosted family travel guide for Japan covering Tokyo, Osaka, Hiroshima, Kanazawa, Takayama, and Nagano."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,500;9..144,700&family=Manrope:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""
    />
    <link rel="stylesheet" href="assets/site.css" />
  </head>
  <body>
    <div class="page-shell">
      <header class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Family Guide | {{ data.meta.travel_window }}</p>
          <h1>{{ data.meta.title }}</h1>
          <p class="lede">{{ data.meta.subtitle }}</p>
          <p class="summary">{{ data.meta.high_level_summary }}</p>
          <div class="note">
            <strong>Planning note:</strong> fares were checked online on {{ data.meta.source_checked_date }}. Some operator fare tables are older revision PDFs, so treat all transport costs as planning estimates, not locked fares.
            <br />
            <strong>FX note:</strong> AUD conversions use the AUD/JPY market close of {{ data.meta.fx.aud_jpy_close }} on {{ data.meta.fx.date }}. See {{ data.meta.fx.source_id }} in the citations list.
          </div>
        </div>
        <div class="hero-stats">
          {% for card in data.overview_cards %}
          <article class="stat-card">
            <p class="stat-label">{{ card.label }}</p>
            <p class="stat-value">{{ card.value }}</p>
            <p class="stat-detail">{{ card.detail }}</p>
          </article>
          {% endfor %}
        </div>
      </header>

      <main>
        <section class="tab-shell">
          <div class="tab-nav" role="tablist" aria-label="Guide tabs">
            <button type="button" class="tab-button is-active" role="tab" id="tab-button-guide" aria-controls="tab-panel-guide" aria-selected="true" data-tab-target="guide">Guide</button>
            <button type="button" class="tab-button" role="tab" id="tab-button-dates" aria-controls="tab-panel-dates" aria-selected="false" data-tab-target="dates">Dates and Times</button>
            <button type="button" class="tab-button" role="tab" id="tab-button-finances" aria-controls="tab-panel-finances" aria-selected="false" data-tab-target="finances">Finances</button>
          </div>

          <section class="tab-panel is-active" id="tab-panel-guide" role="tabpanel" aria-labelledby="tab-button-guide">
            <section class="section">
              <div class="section-head">
                <p class="kicker">Route</p>
                <h2>Main route map</h2>
                <p>
                  This is the cleanest version of your route for a 20-night trip: four nights in Tokyo, four in Osaka, three in Hiroshima, then the Hokuriku/Hida/Nagano arc before a final Tokyo finish.
                </p>
              </div>
              <div class="map-frame">
                <div id="route-overview" class="map"></div>
              </div>
            </section>

            <section class="section two-column">
              <div>
                <div class="section-head">
                  <p class="kicker">Pacing</p>
                  <h2>Itinerary at a glance</h2>
                </div>
                <div class="table-card">
                  <table class="sheet-table">
                    <thead>
                      <tr>
                        <th>Item</th>
                        <th>Details</th>
                      </tr>
                    </thead>
                    {% for row in data.itinerary_rows %}
                    <tbody class="sheet-group">
                      <tr>
                        <th colspan="2" class="sheet-group-heading">{{ row.base }}</th>
                      </tr>
                      <tr>
                        <td class="sheet-label">Dates</td>
                        <td class="sheet-value">{{ row.dates }}</td>
                      </tr>
                      <tr>
                        <td class="sheet-label">Nights</td>
                        <td class="sheet-value">{{ row.nights }}</td>
                      </tr>
                      <tr>
                        <td class="sheet-label">Suggested rhythm</td>
                        <td class="sheet-value">{{ row.rhythm }}</td>
                      </tr>
                    </tbody>
                    {% endfor %}
                  </table>
                </div>
              </div>
              <div>
                <div class="section-head">
                  <p class="kicker">Assumption</p>
                  <h2>How the 50/50 split works</h2>
                </div>
                <div class="callout">
                  <p>
                    Your short two-night stops are where a literal 50/50 split gets awkward, so this guide treats the
                    whole trip as the unit of balance instead of every single base.
                  </p>
                  <p>
                    Result: <strong>{{ data.meta.city_focus_days }} city-focus days</strong> and
                    <strong>{{ data.meta.excursion_days }} out-of-city days</strong>, with transfer days doing some of the work in Hokuriku and Hida.
                  </p>
                  <p>{{ data.meta.family_assumption }}</p>
                </div>
              </div>
            </section>

            <section class="section">
              <div class="section-head">
                <p class="kicker">Flight Options</p>
                <h2>Direct Japan vs a 2-night Singapore stop</h2>
                <p>
                  This keeps the main flight comparison inside the core guide. The Singapore option only makes sense if you actively want the stopover, because it gives away Japan time without producing a clearly better flight-only cost.
                </p>
              </div>
              <div class="table-card flight-table-card">
                <table class="flight-table">
                  <thead>
                    <tr>
                      <th>Item</th>
                      <th>Details</th>
                    </tr>
                  </thead>
                  {% for row in data.flight_options %}
                  <tbody class="flight-option-group">
                    <tr>
                      <th colspan="2" class="flight-option-heading">{{ row.name }}</th>
                    </tr>
                    <tr>
                      <td class="flight-item-label">Flight pattern</td>
                      <td><div class="flight-cell-main">{{ row.pattern }}</div></td>
                    </tr>
                    <tr>
                      <td class="flight-item-label">Air time</td>
                      <td><div class="flight-cell-main">{{ row.air_time }}</div></td>
                    </tr>
                    <tr>
                      <td class="flight-item-label">Economy flight cost</td>
                      <td>
                        <div class="flight-price">{{ row.flight_cost }} per person</div>
                        <div class="flight-price flight-price-sub">{{ row.family_cost }} for 4 people</div>
                        <div class="flight-breakdown-list">
                          {% for item in row.price_breakdown %}
                          <div class="flight-breakdown-item">{{ item }}</div>
                          {% endfor %}
                        </div>
                      </td>
                    </tr>
                    <tr>
                      <td class="flight-item-label">Japan time impact</td>
                      <td><div class="flight-cell-main">{{ row.japan_time }}</div></td>
                    </tr>
                    <tr>
                      <td class="flight-item-label">Planning notes</td>
                      <td>
                        <div class="flight-cell-main">{{ row.notes }}</div>
                        <div class="source-strip">
                          {% for source_id in row.source_ids %}
                          <a href="{{ data.citations_by_id[source_id].url }}">{{ source_id }}</a>
                          {% endfor %}
                        </div>
                      </td>
                    </tr>
                  </tbody>
                  {% endfor %}
                </table>
              </div>
            </section>

            <section class="section two-column">
              <div>
                <div class="section-head">
                  <p class="kicker">Trip Math</p>
                  <h2>How many days are you actually in Japan?</h2>
                </div>
                <div class="callout">
                  <p>{{ data.japan_time_math.assumption }}</p>
                  <p>{{ data.japan_time_math.outbound }}</p>
                  <p>{{ data.japan_time_math.return }}</p>
                  <p>
                    Result:
                    <strong>{{ data.japan_time_math.nights }} nights in Japan</strong>,
                    <strong>{{ data.japan_time_math.calendar_days }} calendar dates touched</strong>,
                    and <strong>{{ data.japan_time_math.full_days }} full sightseeing days between arrival and departure</strong>.
                  </p>
                  <div class="source-strip">
                    {% for source_id in data.japan_time_math.source_ids %}
                    <a href="{{ data.citations_by_id[source_id].url }}">{{ source_id }}</a>
                    {% endfor %}
                  </div>
                </div>
              </div>
              <div>
                <div class="section-head">
                  <p class="kicker">Interpretation</p>
                  <h2>What that means for planning</h2>
                </div>
                <div class="callout">
                  <p>
                    Your earlier 20-night structure is still the right planning shape. The useful correction is that the trip gives you
                    <strong>19 full sightseeing days</strong>, not 20 or 21 fully usable days.
                  </p>
                  <p>
                    If you choose the Singapore stopover instead, the Japan portion drops to
                    <strong>18 nights and 17 full sightseeing days</strong>.
                  </p>
                </div>
              </div>
            </section>

            <section class="section">
              <div class="section-head">
                <p class="kicker">Must-Dos</p>
                <h2>Your wife's requested additions</h2>
                <p>
                  These are now placed into the route where they fit best, rather than left as a separate wish list. Where I had to choose between two valid options, I picked the cleaner fit for this exact itinerary and noted the alternate.
                </p>
              </div>
              <div class="food-grid">
                {% for item in data.requested_highlights %}
                <article class="food-card">
                  <h3>{{ item.title }}</h3>
                  <p><strong>Best base:</strong> {{ item.base }}</p>
                  <p><strong>Best slot:</strong> {{ item.best_slot }}</p>
                  <p><strong>Budget note:</strong> {{ item.cost }}</p>
                  <p>{{ item.notes }}</p>
                  <div class="source-strip">
                    {% for source_id in item.source_ids %}
                    <a href="{{ data.citations_by_id[source_id].url }}">{{ source_id }}</a>
                    {% endfor %}
                  </div>
                </article>
                {% endfor %}
              </div>
            </section>

            <section class="section">
              <div class="section-head">
                <p class="kicker">Transport</p>
                <h2>Intercity cost estimate</h2>
                <p>
                  These are the one-way planning numbers between each main base in Japan. Use the finances tab if you want the same data in one consolidated ledger.
                </p>
              </div>
              <div class="table-card">
                <table class="sheet-table">
                  <thead>
                    <tr>
                      <th>Item</th>
                      <th>Details</th>
                    </tr>
                  </thead>
                  {% for row in data.intercity_segments %}
                  <tbody class="sheet-group">
                    <tr>
                      <th colspan="2" class="sheet-group-heading">{{ row.from }} → {{ row.to }}</th>
                    </tr>
                    <tr>
                      <td class="sheet-label">Mode</td>
                      <td class="sheet-value">{{ row.mode }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Time</td>
                      <td class="sheet-value">{{ row.duration }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Adult estimate</td>
                      <td class="sheet-value">{{ row.adult_cost_label }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Family of 4</td>
                      <td class="sheet-value">{{ row.family_cost_label }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Notes</td>
                      <td>
                        {{ row.notes }}
                        <div class="table-links">
                          <a href="{{ row.maps_url }}">Map route</a>
                        </div>
                        <div class="source-strip">
                          {% for source_id in row.source_ids %}
                          <a href="{{ data.citations_by_id[source_id].url }}">{{ source_id }}</a>
                          {% endfor %}
                        </div>
                      </td>
                    </tr>
                  </tbody>
                  {% endfor %}
                </table>
              </div>
            </section>

            <section class="section">
              <div class="section-head">
                <p class="kicker">Day Trips</p>
                <h2>Base-to-excursion transport estimate</h2>
                <p>
                  These are the out-of-city transport numbers that sit behind the 50/50 city-versus-day-trip split.
                </p>
              </div>
              <div class="table-card">
                <table class="sheet-table">
                  <thead>
                    <tr>
                      <th>Item</th>
                      <th>Details</th>
                    </tr>
                  </thead>
                  {% for row in data.day_trip_rows %}
                  <tbody class="sheet-group">
                    <tr>
                      <th colspan="2" class="sheet-group-heading">{{ row.base }} → {{ row.trip }}</th>
                    </tr>
                    <tr>
                      <td class="sheet-label">Adult estimate</td>
                      <td class="sheet-value">{{ row.adult_cost_label }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Family of 4</td>
                      <td class="sheet-value">{{ row.family_cost_label }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Notes</td>
                      <td>
                        {{ row.notes }}
                        <div class="source-strip">
                          {% for source_id in row.source_ids %}
                          <a href="{{ data.citations_by_id[source_id].url }}">{{ source_id }}</a>
                          {% endfor %}
                        </div>
                      </td>
                    </tr>
                  </tbody>
                  {% endfor %}
                </table>
              </div>
            </section>

            <section class="section">
              <div class="section-head">
                <p class="kicker">Food</p>
                <h2>Expected daily food cost</h2>
                <p>
                  These are the working daily food ranges for each stop, with the likely bump for excursion days.
                </p>
              </div>
              <div class="table-card">
                <table class="sheet-table">
                  <thead>
                    <tr>
                      <th>Item</th>
                      <th>Details</th>
                    </tr>
                  </thead>
                  {% for item in data.food_budgets %}
                  <tbody class="sheet-group">
                    <tr>
                      <th colspan="2" class="sheet-group-heading">{{ item.location }}</th>
                    </tr>
                    <tr>
                      <td class="sheet-label">Per person</td>
                      <td class="sheet-value">{{ item.per_person_label }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Family of 4</td>
                      <td class="sheet-value">{{ item.family_of_four_label }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Day-trip bump</td>
                      <td class="sheet-value">{{ item.day_trip_add_on }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Notes</td>
                      <td>
                        {{ item.notes }}
                        <div class="source-strip">
                          {% for source_id in item.source_ids %}
                          <a href="{{ data.citations_by_id[source_id].url }}">{{ source_id }}</a>
                          {% endfor %}
                        </div>
                      </td>
                    </tr>
                  </tbody>
                  {% endfor %}
                </table>
              </div>
            </section>

            {% for stay in data.stays %}
            <section class="section stay-section" id="{{ stay.slug }}">
              <div class="section-head">
                <p class="kicker">{{ stay.region }}</p>
                <h2>{{ stay.name }} | {{ stay.nights }} nights</h2>
                <p>{{ stay.summary }}</p>
                <p class="date-line">{{ stay.dates }}</p>
              </div>

              <div class="stay-layout">
                <div class="stay-column">
                  <article class="panel">
                    <h3>If 50% of the time stays in the city</h3>
                    <ul class="bullet-list">
                      {% for item in stay.city_focus %}
                      <li>{{ item }}</li>
                      {% endfor %}
                    </ul>
                  </article>

                  <article class="panel">
                    <h3>Food budget in {{ stay.name }}</h3>
                    <p><strong>Per person:</strong> {{ stay.food_budget.per_person_label }}</p>
                    <p><strong>Family of 4:</strong> {{ stay.food_budget.family_of_four_label }}</p>
                    <p>{{ stay.food_budget.notes }}</p>
                  </article>
                </div>

                <div class="stay-column">
                  <article class="panel">
                    <h3>If the other 50% goes outside the city</h3>
                    {% if stay.day_trips %}
                    <div class="trip-cards">
                      {% for trip in stay.day_trips %}
                      <div class="trip-card">
                        <div class="trip-topline">
                          <h4>{{ trip.name }}</h4>
                          <span>{{ trip.duration }}</span>
                        </div>
                        <p>{{ trip.notes }}</p>
                        <p><strong>Transport:</strong> {{ trip.transport }}</p>
                        <p><strong>Adult estimate:</strong> {{ trip.adult_cost_label }}</p>
                        <p><strong>Family of 4:</strong> {{ trip.family_cost_label }}</p>
                        <p><a href="{{ trip.maps_url }}">Open route in Google Maps</a></p>
                        <div class="source-strip">
                          {% for source_id in trip.source_ids %}
                          <a href="{{ data.citations_by_id[source_id].url }}">{{ source_id }}</a>
                          {% endfor %}
                        </div>
                      </div>
                      {% endfor %}
                    </div>
                    {% else %}
                    <p>
                      This return-Tokyo block works better as a buffer and catch-up stay than as another fixed day-trip base. That reduces weather risk and makes your last days materially easier.
                    </p>
                    {% endif %}
                  </article>

                  <article class="panel">
                    <h3>{{ stay.name }} map</h3>
                    <div id="map-{{ stay.slug }}" class="map small-map"></div>
                  </article>
                </div>
              </div>

              <div class="source-row">
                <span>Sources for {{ stay.name }}:</span>
                {% for source_id in stay.source_ids %}
                <a href="{{ data.citations_by_id[source_id].url }}">{{ source_id }}</a>
                {% endfor %}
              </div>
            </section>
            {% endfor %}

            <section class="section">
              <div class="section-head">
                <p class="kicker">Sources</p>
                <h2>Citations</h2>
                <p>
                  These are the sources used to shape the guide. Where a number is an estimate rather than a single posted operator fare, the note says so explicitly.
                </p>
              </div>
              <div class="sources">
                {% for citation in data.citations %}
                <article class="source-card" id="{{ citation.id }}">
                  <p class="source-id">{{ citation.id }}</p>
                  <h3>{{ citation.title }}</h3>
                  <p>{{ citation.publisher }}</p>
                  <p><a href="{{ citation.url }}">{{ citation.url }}</a></p>
                  <p>Accessed {{ citation.accessed }}</p>
                  <p>{{ citation.note }}</p>
                </article>
                {% endfor %}
              </div>
            </section>
          </section>

          <section class="tab-panel" id="tab-panel-dates" role="tabpanel" aria-labelledby="tab-button-dates" hidden>
            <section class="section two-column">
              <div>
                <div class="section-head">
                  <p class="kicker">Trip Math</p>
                  <h2>How many days are you actually in Japan?</h2>
                </div>
                <div class="callout">
                  <p>{{ data.japan_time_math.assumption }}</p>
                  <p>{{ data.japan_time_math.outbound }}</p>
                  <p>{{ data.japan_time_math.return }}</p>
                  <p>
                    Result:
                    <strong>{{ data.japan_time_math.nights }} nights in Japan</strong>,
                    <strong>{{ data.japan_time_math.calendar_days }} calendar dates touched</strong>,
                    and <strong>{{ data.japan_time_math.full_days }} full sightseeing days between arrival and departure</strong>.
                  </p>
                  <div class="source-strip">
                    {% for source_id in data.japan_time_math.source_ids %}
                    <a href="{{ data.citations_by_id[source_id].url }}">{{ source_id }}</a>
                    {% endfor %}
                  </div>
                </div>
              </div>
              <div>
                <div class="section-head">
                  <p class="kicker">Interpretation</p>
                  <h2>What that means for planning</h2>
                </div>
                <div class="callout">
                  <p>
                    Your earlier 20-night structure is still the right planning shape. The useful correction is that the trip gives you
                    <strong>19 full sightseeing days</strong>, not 20 or 21 fully usable days.
                  </p>
                  <p>
                    If you choose the Singapore stopover instead, the Japan portion drops to
                    <strong>18 nights and 17 full sightseeing days</strong>.
                  </p>
                </div>
              </div>
            </section>

            <section class="section">
              <div class="section-head">
                <p class="kicker">Dates and Times</p>
                <h2>Simple date and time table</h2>
                <p>
                  This table pulls together the trip windows, flight assumptions, and the timed or date-sensitive places in one place.
                </p>
              </div>
              <div class="table-card">
                <table class="sheet-table">
                  <thead>
                    <tr>
                      <th>Item</th>
                      <th>Details</th>
                    </tr>
                  </thead>
                  {% for row in data.dates_and_times_rows %}
                  <tbody class="sheet-group">
                    <tr>
                      <th colspan="2" class="sheet-group-heading">{{ row.place }}</th>
                    </tr>
                    <tr>
                      <td class="sheet-label">Scenario</td>
                      <td class="sheet-value">{{ row.scenario }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Date / window</td>
                      <td class="sheet-value">{{ row.date_window }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Time / duration</td>
                      <td class="sheet-value">{{ row.time_detail }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Notes</td>
                      <td>
                        {{ row.notes }}
                        {% if row.source_ids %}
                        <div class="source-strip">
                          {% for source_id in row.source_ids %}
                          <a href="{{ data.citations_by_id[source_id].url }}">{{ source_id }}</a>
                          {% endfor %}
                        </div>
                        {% endif %}
                      </td>
                    </tr>
                  </tbody>
                  {% endfor %}
                </table>
              </div>
            </section>
          </section>

          <section class="tab-panel" id="tab-panel-finances" role="tabpanel" aria-labelledby="tab-button-finances" hidden>
            <section class="section">
              <div class="section-head">
                <p class="kicker">Finances</p>
                <h2>All key cost data in one table</h2>
                <p>
                  This is the consolidated cost table for flights, intercity transport, day trips, daily food, and the main paid activities already discussed. Accommodation is still not estimated here.
                </p>
              </div>
              <div class="table-card">
                <table class="sheet-table">
                  <thead>
                    <tr>
                      <th>Item</th>
                      <th>Details</th>
                    </tr>
                  </thead>
                  {% for row in data.finance_rows %}
                  <tbody class="sheet-group">
                    <tr>
                      <th colspan="2" class="sheet-group-heading">{{ row.item }}</th>
                    </tr>
                    <tr>
                      <td class="sheet-label">Category</td>
                      <td class="sheet-value">{{ row.category }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Per person</td>
                      <td class="sheet-value">{{ row.per_person }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Family of 4</td>
                      <td class="sheet-value">{{ row.family }}</td>
                    </tr>
                    <tr>
                      <td class="sheet-label">Notes</td>
                      <td>
                        {{ row.notes }}
                        {% if row.source_ids %}
                        <div class="source-strip">
                          {% for source_id in row.source_ids %}
                          <a href="{{ data.citations_by_id[source_id].url }}">{{ source_id }}</a>
                          {% endfor %}
                        </div>
                        {% endif %}
                      </td>
                    </tr>
                  </tbody>
                  {% endfor %}
                </table>
              </div>
            </section>
          </section>
        </section>
      </main>
    </div>

    <script
      src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
      crossorigin=""
    ></script>
    <script>
      const MAPS = {{ maps_json | safe }};
      const MAP_INSTANCES = [];

      function buildMap(entry) {
        const el = document.getElementById(entry.id);
        if (!el) return;

        const map = L.map(el, {
          scrollWheelZoom: false,
          zoomControl: true
        });

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          maxZoom: 18,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(map);

        const latlngs = entry.points.map((point) => point.coord);
        entry.points.forEach((point, index) => {
          const marker = L.marker(point.coord).addTo(map);
          marker.bindPopup(`<strong>${index + 1}. ${point.name}</strong>`);
        });

        if (latlngs.length > 1) {
          L.polyline(latlngs, {
            color: "#b6552f",
            weight: 4,
            opacity: 0.85
          }).addTo(map);
        }

        const bounds = L.latLngBounds(latlngs);
        if (latlngs.length === 1) {
          map.setView(latlngs[0], 11);
        } else {
          map.fitBounds(bounds.pad(0.2));
        }

        MAP_INSTANCES.push(map);
      }

      MAPS.forEach(buildMap);

      const tabButtons = Array.from(document.querySelectorAll(".tab-button"));
      const tabPanels = Array.from(document.querySelectorAll(".tab-panel"));

      function showTab(target) {
        tabButtons.forEach((button) => {
          const active = button.dataset.tabTarget === target;
          button.classList.toggle("is-active", active);
          button.setAttribute("aria-selected", active ? "true" : "false");
        });

        tabPanels.forEach((panel) => {
          const active = panel.id === `tab-panel-${target}`;
          panel.classList.toggle("is-active", active);
          panel.hidden = !active;
        });

        if (target === "guide") {
          window.requestAnimationFrame(() => {
            MAP_INSTANCES.forEach((map) => map.invalidateSize());
          });
        }
      }

      tabButtons.forEach((button) => {
        button.addEventListener("click", () => showTab(button.dataset.tabTarget));
      });
    </script>
  </body>
</html>
